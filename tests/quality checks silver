--For table 'bronze.crm_prd_info'
-----------------------------------
--check for nulls or duplicaties in the prod_key 
--Expectation : no duplicats


SELECT 
prd_key,
COUNT(*)
FROM bronze.crm_prd_info
GROUP BY prd_key
HAVING COUNT(*) > 1 OR prd_key IS NULL
---

/* Why didn`t we validate uniqueness using the primary key (prd_id)?

The Product table follows a Slowly Changing Dimension (SCD Type 2) pattern.
Therefore, uniqueness is validated using (prd_key + prd_start_dt)
instead of prd_id.
*/

-- To standardize cat_id between crm_prd_info and erp_px_cat_g1v2,
-- replace '-' with '_' to ensure consistent formatting.
SELECT 
prd_id,
prd_key,
REPLACE (SUBSTRING(prd_key,1,5), '-' ,'_')  AS cat_id ,
prd_nm,
prd_cost,
prd_line,
prd_start_dt,
prd_end_dt
FROM bronze.crm_prd_info
WHERE REPLACE (SUBSTRING(prd_key,1,5), '-' ,'_')  NOT IN (
SELECT DISTINCT id FROM bronze.erp_px_cat_g1v2)

-- To standardize prd_key between crm_prd_info and crm_sales_details,
-- extract the product identifier starting from position 7.
SELECT 
prd_id,
prd_key,
REPLACE (SUBSTRING(prd_key,1,5), '-' ,'_')  AS cat_id ,
SUBSTRING(prd_key,7,len(prd_key))  AS	prd_key ,
prd_nm,
prd_cost,
prd_line,
prd_start_dt,
prd_end_dt
FROM bronze.crm_prd_info
WHERE SUBSTRING(prd_key,7,len(prd_key))
 NOT IN (
SELECT DISTINCT sls_prd_key FROM bronze.crm_sales_details)


-- ckeck the prd_cost nulls or douplicaties 
SELECT prd_cost ,prd_id
FROM bronze.crm_prd_info
WHERE prd_cost < 0 OR prd_cost IS NULL 

--to solve it

SELECT 
prd_id,

ISNULL(prd_cost,0) AS prd_cost
FROM bronze.crm_prd_info

-- Standardized prd_line values by replacing coded values with descriptive names and replacing NULLs with 'n/a'.

SELECT
CASE UPPER(TRIM(prd_line))
	 WHEN 'M' THEN 'Mountain'
	 WHEN 'R' THEN 'Road'
	 WHEN 'S' THEN 'Other Sales'
	 WHEN 'T' THEN 'Touring'
	 ELSE 'n/a'
END AS prd_line
FROM bronze.crm_prd_info


/* Check date validity:
Ensure prd_end_dt is not earlier than prd_start_dt.

To resolve this:
Keep prd_start_dt as is and calculate prd_end_dt
as one day before the next prd_start_dt
for the same product (SCD logic).
*/


SELECT *
FROM bronze.crm_prd_info
WHERE prd_end_dt < prd_start_dt

SELECT 
CAST (prd_start_dt AS DATE ) AS prd_start_dt ,
CAST (LEAD (prd_start_dt) OVER (PARTITION BY prd_key ORDER BY prd_start_dt)-1 AS DATE) AS prd_end_dt
FROM bronze.crm_prd_info

/*
the final quary
WHAT WE DID HERE?

- Double-checked that prd_id has no duplicates → result is clean.
- Extracted the category ID from prd_key.
- Extracted the product ID from prd_key.
- Replaced NULL values in prd_cost with 0 and ensured there are no negative values.
- Standardized prd_line values by replacing coded values with descriptive names and replacing NULLs with 'n/a'.
- Calculated prd_end_dt as one day before the next prd_start_dt (for the same product).
- Adjusted the Silver layer table structure to match the new modifications.
- Inserted the cleaned and transformed data into the Silver layer table.

*/


SELECT 
prd_id,
REPLACE (SUBSTRING(prd_key,1,5), '-' ,'_')  AS cat_id ,
SUBSTRING(prd_key,7,len(prd_key))  AS prd_key ,
prd_nm,
ISNULL(prd_cost,0) AS prd_cost,
CASE UPPER(TRIM(prd_line))
	 WHEN 'M' THEN 'Mountain'
	 WHEN 'R' THEN 'Road'
	 WHEN 'S' THEN 'Other Sales'
	 WHEN 'T' THEN 'Touring'
	 ELSE 'n/a'
END AS prd_line,
CAST (prd_start_dt AS DATE ) AS prd_start_dt ,
CAST (LEAD (prd_start_dt) OVER (PARTITION BY prd_key ORDER BY prd_start_dt)-1 AS DATE) AS prd_end_dt
FROM bronze.crm_prd_info

